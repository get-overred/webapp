[
    {
        "title": "DOCUMENT",
        "inputs": [
            {
                "id": "document_bg_color",
                "type": "color",
                "label": "Background Color"
            },
            {
                "id": "document_padding",
                "type": "range",
                "label": "Padding",
                "range_min": "0",
                "range_max": "100",
                "range_step": "5"
            },
            {
                "id": "document_space_y",
                "type": "range",
                "label": "Y-Spacing",
                "range_min": "0",
                "range_max": "200",
                "range_step": "5"
            },
            {
                "id": "document_width",
                "type": "text",
                "label": "Width"
            },
            {
                "id": "document_height",
                "type": "text",
                "label": "Height"
            },
            {
                "id": "editor_scale",
                "display": "NO"
            }
        ]
    },
    {
        "title": "TEXT",
        "inputs": [
            {
                "id": "document_txt_font",
                "type": "select",
                "label": "Text Fonts",
                "selectors": [
                    "Helvetica",
                    "Arial",
                    "Times New Roman",
                    "Georgia",
                    "Trebuchet MS",
                    "Verdana",
                    "Monaco"
                ]
            },
            {
                "id": "document_h_txt_color",
                "type": "color",
                "label": "Heading Color"
            },
            {
                "id": "document_h_txt_size",
                "type": "text",
                "label": "Heading Size"
            },
            {
                "id": "document_h_txt_weight",
