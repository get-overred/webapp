            {
                "id": "document_h_txt_align",
                "type": "multi_button",
                "label": "Heading Align",
                "selectors": [
                    {
                        "value": "start",
                        "icon": "fa-solid fa-align-left"
                    },
                    {
                        "value": "center",
                        "icon": "fa-solid fa-align-center"
                    },
                    {
                        "value": "end",
                        "icon": "fa-solid fa-align-right"
                    },
                    {
                        "value": "justify",
                        "icon": "fa-solid fa-align-justify"
                    }
                ]
            },
            {
                "id": "document_p_txt_color",
                "type": "color",
                "label": "Body Color"
            },
            {
                "id": "document_p_txt_size",
                "type": "text",
                "label": "Body Size"
            },
            {
                "id": "document_p_txt_weight",
                "type": "range",
                "label": "Body Weight",
                "range_min": "100",
                "range_max": "900",
                "range_step": "100"
            },
            {
                "id": "document_p_txt_align",
                "type": "multi_button",
                "label": "Body Align",
                "selectors": [
                    {
                        "value": "start",
                        "icon": "fa-solid fa-align-left"
                    },
                    {
                        "value": "center",
                        "icon": "fa-solid fa-align-center"
                    },
                    {
                        "value": "end",
                        "icon": "fa-solid fa-align-right"
                    },
                    {
                        "value": "justify",
                        "icon": "fa-solid fa-align-justify"
                    }
                ]
            }
        ]
    },
    {
        "title": "SCREENSHOT",
        "inputs": [
            {
                "id": "target_bg_color",
                "type": "color",
                "label": "Target Color"
            },
            {
                "id": "target_border_radius",
                "type": "range",
                "label": "Target Border-Radius",
                "range_min": "0",
                "range_max": "100",
                "range_step": "5"
            },
            {
                "id": "target_no_fillout",
                "type": "checkbox",
                "label": "Target only Border"
            },
            {
                "id": "target_replace_cursor",
                "type": "checkbox",
                "label": "Target as Cursor"
            },
            {
                "id": "target_enable_arrow",
                "type": "checkbox",
                "label": "Point an Arrow"
            },
            {
                "id": "image_border_radius",
                "type": "range",
                "label": "Image Border-Radius",
                "range_min": "0",
                "range_max": "500",
                "range_step": "25"
            },
            {
                "id": "target_scale_factor",
                "type": "range",
                "label": "Scale to Target",
                "range_min": "1.0",
                "range_max": "7.5",
                "range_step": "0.1"
            },
            {
                "id": "image_size_perc",
                "type": "range",
                "label": "Image Size",
                "range_min": "25",
                "range_max": "100",
                "range_step": "2.5"
            },
            {
                "id": "image_border_width",
                "type": "range",
                "label": "Image Border-Width",
                "range_min": "0.5",
                "range_max": "19",
                "range_step": "0.5"
            },
            {
                "id": "image_border_type",
                "type": "select",
                "label": "Image Border-Type",
                "selectors": [
                    "Solid",
                    "Dashed",
                    "Double",
                    "Inset",
                    "Outset",
                    "Ridge"
                ]
            },
            {
                "id": "image_border_color",
                "type": "color",
                "label": "Image Border-Color"
            }
        ]
    },
    {
        "title": "EXPORT",
        "inputs": [
            {
                "id": "pdf",
                "type": "export",
                "label": "to PDF",
                "icon": "fa-regular fa-file-pdf",
                "value": null
            },
            {
                "id": "docx",
                "type": "export",
                "label": "to Word",
                "icon": "fa-regular fa-file-word",
                "value": null
            },
            {
                "id": "html",
                "type": "export",
                "label": "to HTML",
                "icon": "fa-regular fa-file-code",
                "value": null
            }
        ]
    }
]